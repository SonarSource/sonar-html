{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "local>SonarSource/core-languages-tooling-public:renovate-config"
  ],
  "ignorePaths": [
    "its/sources/**",
    "its/plugin/projects/**"
  ],
  "packageRules": [
    {
      "matchManagers": [
        "github-actions"
      ],
      "pinDigests": false
    },
    {
      "matchManagers": [
        "github-actions"
      ],
      "matchUpdateTypes": [
        "pin",
        "rollback"
      ],
      "enabled": false
    },
    {
      "matchPackageNames": [
        "org.sonarsource.html:html-its"
      ],
      "enabled": false
    }
  ]
}
